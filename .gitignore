# Local Python environments and caches
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated datasets, training runs, and build artifacts
data/
runs/
build/
dist/
*.egg-info/

# OMX runtime state; plans and specifications remain reviewable
.omx/state/
.omx/logs/
.omx/cache/

# Bootstrap reports emitted when the shared writer lock cannot be used
.bitguard-bootstrap-failure-*.json
.bitguard-bootstrap-*-failure-*.json
